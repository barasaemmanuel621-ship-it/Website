body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f8f8f8;
}

header {
  background: #0b5d3b;
  color: white;
  padding: 15px;
}

nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

nav ul {
  display: flex;
  list-style: none;
}

nav ul li {
  margin-left: 20px;
}

nav a {
  color: white;
  text-decoration: none;
}

.hero {
  text-align: center;
  padding: 80px 20px;
  background: linear-gradient(to right, #0b5d3b, #14532d);
  color: white;
}

.hero button {
  padding: 12px 25px;
  border: none;
  background: gold;
  cursor: pointer;
}

.products {
  padding: 40px;
  text-align: center;
}

.product-card {
  display: inline-block;
  background: white;
  padding: 20px;
  margin: 15px;
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.product-card button {
  background: #0b5d3b;
  color: white;
  border: none;
  padding: 10px 15px;
}

.about, .contact {
  padding: 40px;
  text-align: center;
}

footer {
  background: black;
  color: white;
  text-align: center;
  padding: 20px;
}
